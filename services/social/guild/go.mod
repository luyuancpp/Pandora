module github.com/luyuancpp/pandora/services/social/guild

go 1.26.4

// guild 服务(Pandora 社交域公会 + 临时群,2026-06-27)。
//
// 职责(docs/design/decision-revisit-chat-group.md):
//   公会成员管理(GuildService)+ 临时群成员管理(GroupService),同进程双 service;
//   成员关系落 pandora_social 库(MySQL 强依赖);
//   公会成员变更经 kafka pandora.guild.event → push 推送给接收方(弱依赖);
//   支撑 chat 服务的 GUILD / GROUP 频道 fan-out(chat 经 gRPC 调本服务解析成员)。
//
// 依赖来源:
//   - pkg/        (公共框架,go.work use:mysqlx / kafkax / snowflake / grpcserver)
//   - proto/      (guild/v1 + group/v1 + common/v1)
//   - Kratos v2.9.2 / IBM/sarama(guild.event 生产)/ go-sql-driver/mysql(pandora_social)

require (
	github.com/IBM/sarama v1.43.1
	github.com/go-kratos/kratos/v2 v2.9.2
	github.com/luyuancpp/pandora/pkg v0.0.0-00010101000000-000000000000
	github.com/luyuancpp/pandora/proto v0.0.0-00010101000000-000000000000
	google.golang.org/protobuf v1.36.11
)

